[
  {
    "id": "plague_outbreak",
    "name": "疫病爆发",
    "open_effects": [
      {"scope": "tile_state", "state": "plague"},
      {"scope": "tile_state", "state": "panic"}
    ],
    "actions": [
      {
        "id": "resolve_cleanse_plague",
        "name": "净化疫病",
        "requirements": [
          {"key": "cure_progress", "op": ">=", "value": 3, "reason": "治疗进度需要 3"},
          {"key": "source_clues", "op": ">=", "value": 2, "reason": "病源线索需要 2"}
        ],
        "preview": [
          {"key": "cure_progress", "label": "治疗", "value": 3},
          {"key": "source_clues", "label": "线索", "value": 2}
        ],
        "effects": [
          {"scope": "tile_state", "state": "plague", "op": "remove"},
          {"scope": "tile_state", "state": "polluted", "op": "remove"},
          {"scope": "tile_state", "state": "panic", "op": "remove"},
          {"scope": "tile_state", "state": "blessed"},
          {"scope": "tile_claim"},
          {"scope": "global_resource", "key": "faith", "delta": 2},
          {"scope": "global_resource", "key": "followers", "delta": 1},
          {"scope": "experience", "delta": 3},
          {"scope": "route_affinity", "route": "life", "delta": 2},
          {"scope": "sanity_status", "value": "稳定"},
          {"scope": "event_summary", "text": "病村被净化，治愈传说开始流传"},
          {"scope": "log", "text": "最终事件：你净化了疫病。病村获得祝福，生命路线倾向上升。"}
        ]
      },
      {
        "id": "resolve_prayer_circle",
        "name": "集体祈祷",
        "requirements": [
          {"key": "followers", "op": ">=", "value": 2, "reason": "信徒需要 2"},
          {"key": "faith", "op": ">=", "value": 4, "reason": "信仰需要 4"},
          {"key": "public_trust", "op": ">=", "value": 1, "reason": "需要村民信任"}
        ],
        "preview": [
          {"key": "followers", "label": "信徒", "value": 2},
          {"key": "faith", "label": "信仰", "value": 4},
          {"key": "public_trust", "label": "信任", "value": 1}
        ],
        "effects": [
          {"scope": "tile_state", "state": "panic", "op": "remove"},
          {"scope": "tile_state", "state": "anchor"},
          {"scope": "tile_claim"},
          {"scope": "tile_building", "building": "secret_shrine", "if_empty": true},
          {"scope": "global_resource", "key": "faith", "delta": 3},
          {"scope": "global_resource", "key": "followers", "delta": 2},
          {"scope": "secrecy_pressure", "delta": 1},
          {"scope": "experience", "delta": 3},
          {"scope": "route_affinity", "route": "faith", "delta": 2},
          {"scope": "event_summary", "text": "村民集体祈祷，病村成为神名锚点"},
