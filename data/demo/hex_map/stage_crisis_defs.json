        ]
      },
      {
        "id": "resolve_death_authority",
        "name": "死亡回响",
        "requirements": [
          {"key": "death_route", "op": ">=", "value": 3, "reason": "死亡倾向需要 3"},
          {"key": "materials", "op": ">=", "value": 1, "reason": "材料需要 1"}
        ],
        "preview": [
          {"key": "death_route", "label": "死亡", "value": 3},
          {"key": "materials", "label": "材料", "value": 1}
        ],
        "effects": [
          {"scope": "tile_state", "state": "plague", "op": "remove"},
          {"scope": "tile_state", "state": "polluted"},
          {"scope": "tile_state", "state": "anchor"},
          {"scope": "tile_population", "delta": -1},
          {"scope": "tile_claim"},
          {"scope": "global_resource", "key": "materials", "delta": -1},
          {"scope": "global_resource", "key": "faith", "delta": 2},
          {"scope": "secrecy_pressure", "delta": 1},
          {"scope": "experience", "delta": 3},
          {"scope": "route_affinity", "route": "death", "delta": 3},
          {"scope": "sanity_status", "value": "洞见"},
          {"scope": "event_summary", "text": "疫病被转化为死亡权柄的锚点"},
          {"scope": "log", "text": "最终事件：你没有救下所有人，而是让死亡服从秩序。死亡路线倾向大幅上升。"}
        ]
      },
      {
        "id": "resolve_hidden_escape",
        "name": "隐秘撤离",
        "requirements": [
          {"key": "exposure", "op": "<=", "value": 1, "reason": "暴露不能高于 1"},
          {"key": "usable_clues", "op": ">=", "value": 1, "reason": "需要至少 1 个线索"}
        ],
        "preview": [
          {"key": "exposure", "label": "暴露", "op": "<=", "value": 1},
          {"key": "usable_clues", "label": "线索", "value": 1}
        ],
        "effects": [
          {"scope": "tile_state", "state": "plague"},
          {"scope": "tile_state", "state": "concealed_tracks"},
          {"scope": "inventory", "item": "suspicious_clue", "delta": 1},
          {"scope": "global_resource", "key": "materials", "delta": 1},
          {"scope": "secrecy_pressure", "delta": -2},
          {"scope": "experience", "delta": 1},
          {"scope": "route_affinity", "route": "secret", "delta": 2},
          {"scope": "event_summary", "text": "你带走病源线索，病村仍陷入瘟疫"},
          {"scope": "log", "text": "最终事件：你隐秘撤离，保住自身与线索，但病村没有被拯救。"}
        ]
      },
      {
        "id": "resolve_plague_failure",
        "name": "放任失控",
        "preview": [],
        "effects": [
          {"scope": "tile_state", "state": "plague"},
          {"scope": "tile_state", "state": "panic"},
          {"scope": "tile_state", "state": "enemy_attention"},
          {"scope": "tile_population", "delta": -1},
          {"scope": "player_life", "delta": -2},
          {"scope": "secrecy_pressure", "delta": 2},
          {"scope": "sanity_status", "value": "动摇"},
          {"scope": "event_summary", "text": "疫病失控，敌对势力注意到你的神迹"},
          {"scope": "log", "text": "最终事件：疫病失控。你受伤并被更多敌对视线锁定。"}
        ]
      }
    ]
  },
